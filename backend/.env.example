# Database Config (Use these defaults for Docker)
POSTGRES_USER=usalama
POSTGRES_PASSWORD=usalama_password
POSTGRES_DB=usalama_db
DATABASE_URL=postgresql+asyncpg://usalama:usalama_password@localhost:5432/usalama_db

# AI Config (Local Ollama)
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=llama3.2:3b

# Security (Generate a new one using: openssl rand -hex 32)
SECRET_KEY=change_this_to_a_secure_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
